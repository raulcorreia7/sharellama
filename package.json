{
  "name": "sharellama",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm test:db:setup && pnpm -r test",
    "smoke": "pnpm exec tsx scripts/smoke.ts --all",
    "smoke:api": "pnpm exec tsx scripts/smoke.ts --api",
    "smoke:ui": "pnpm exec tsx scripts/smoke.ts --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "deploy:api": "pnpm --filter @sharellama/api run deploy",
    "deploy:ui": "pnpm --filter @sharellama/ui run deploy",
    "deploy": "pnpm run deploy:api && pnpm run deploy:ui",
    "dev": "pnpm run dev:api & pnpm run dev:ui",
    "dev:api": "pnpm --filter @sharellama/api run dev",
    "dev:ui": "pnpm --filter @sharellama/ui run dev",
    "dev:db": "pnpm --filter @sharellama/database run db:studio",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:reset": "bash ./scripts/db-reset.sh",
    "db:push": "pnpm --filter @sharellama/database run db:push",
    "db:generate": "pnpm --filter @sharellama/database run db:generate",
    "db:setup": "bash ./scripts/db-setup.sh",
    "test:db:reset": "bash ./scripts/test-db-reset.sh",
    "test:db:setup": "bash ./scripts/test-db-setup.sh",
    "test:api": "bash ./scripts/test-api.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=20"
  }
}
