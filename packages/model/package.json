{
  "name": "@sharellama/model",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schemas/submission": {
      "import": "./dist/schemas/submission.js",
      "types": "./dist/schemas/submission.d.ts"
    },
    "./schemas/vote": {
      "import": "./dist/schemas/vote.js",
      "types": "./dist/schemas/vote.d.ts"
    },
    "./schemas/comment": {
