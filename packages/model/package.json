{
  "name": "@sharellama/model",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./schemas/submission": {
      "import": "./dist/schemas/submission.js",
      "types": "./dist/schemas/submission.d.ts"
    },
    "./schemas/vote": {
      "import": "./dist/schemas/vote.js",
      "types": "./dist/schemas/vote.d.ts"
    },
    "./schemas/comment": {
      "import": "./dist/schemas/comment.js",
      "types": "./dist/schemas/comment.d.ts"
    },
    "./schemas/model": {
      "import": "./dist/schemas/model.js",
      "types": "./dist/schemas/model.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sharellama/core": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3"
  }
}
