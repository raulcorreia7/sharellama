{
  "name": "@sharellama/api-client",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./submissions": {
      "types": "./dist/submissions.d.ts",
      "import": "./dist/submissions.js"
    },
    "./votes": {
      "types": "./dist/votes.d.ts",
      "import": "./dist/votes.js"
    },
    "./comments": {
      "types": "./dist/comments.d.ts",
      "import": "./dist/comments.js"
    },
    "./models": {
      "types": "./dist/models.d.ts",
      "import": "./dist/models.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sharellama/model": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
